# Pelican Panel Docker image version: https://github.com/pelican-dev/panel/releases
PANEL_VERSION=v1.0.0-beta33

# Base URL of the panel including protocol (http:// or https://)
# Local example: http://192.168.1.100
# Production example: https://panel.yourdomain.com
APP_URL=http://localhost

# Email address for Let's Encrypt SSL certificate (only used with https://)
ADMIN_EMAIL=your@email.com